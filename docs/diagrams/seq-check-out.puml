@startuml HMS_Seq_CheckOut
' Author: S2401265 Ahmed Aslan Ibrahim
' Sequence Diagram 3: Front Desk Staff Processes Guest Check-out and Billing

skinparam sequenceArrowThickness 2
skinparam roundcorner 8
skinparam sequenceParticipant underline
skinparam sequence {
  ParticipantBackgroundColor #EEF5FF
  ParticipantBorderColor #336699
  ActorBackgroundColor #FFF8E7
  ActorBorderColor #CC8800
  ArrowColor #336699
  LifeLineBorderColor #336699
}

title Front Desk Staff Processes Guest Check-out & Billing

actor "Front Desk\nStaff" as S
participant "Angular\nFrontend" as UI
participant "CheckInController\n/api/checkin" as CC
participant "BookingManagement\nService" as BS
database "PostgreSQL\nDatabase" as DB

== View Today's Departures ==

S -> UI : Open departures board
activate UI

UI -> CC : GET /api/checkin/departures
activate CC
CC -> BS : GetCheckedInAsync()
activate BS
BS -> DB : SELECT Bookings WHERE status = CheckedIn\nAND checkOutDate <= today
activate DB
DB --> BS : List<BookingDto>
deactivate DB
BS --> CC : List<BookingDto>
deactivate BS
CC --> UI : 200 OK – List<BookingDto>
deactivate CC

UI --> S : Display departures list

== Select Booking & Review Stay ==

S -> UI : Select guest from departures
UI --> S : Display stay summary:\nnights, rooms, ancillary services

== Process Check-out ==

S -> UI : Click "Check Out"
UI -> CC : POST /api/checkin/{bookingId}/checkout
activate CC

CC -> BS : CheckOutAsync(bookingId, staffId)
activate BS

BS -> DB : SELECT Booking JOIN BookingRooms\nJOIN BookingServices JOIN Room
activate DB
DB --> BS : Full booking detail
deactivate DB

BS -> BS : Apply PricingPolicy:\nsum room charges (priceAtBooking × nights)\n+ sum ancillary service fees\n+ tax calculation

BS -> DB : INSERT Invoice\n{invoiceNumber, subtotal, taxAmount, totalAmount}
activate DB
DB --> BS : invoiceId
deactivate DB

BS -> DB : INSERT InvoiceLineItems\n(one per room + one per service)
activate DB
DB --> BS : OK
deactivate DB

BS -> DB : UPDATE Booking status = CheckedOut\nAND totalAmount = finalAmount
activate DB
DB --> BS : OK
deactivate DB

BS -> DB : UPDATE Room status = Cleaning\n(for each room in booking)
activate DB
DB --> BS : OK
deactivate DB

BS -> DB : INSERT AuditLog\n(CheckOutProcessed, staffId, bookingId)
activate DB
DB --> BS : OK
deactivate DB

BS --> CC : BookingDto {status: CheckedOut, invoice: {invoiceNumber, totalAmount}}
deactivate BS

CC --> UI : 200 OK – BookingDto
deactivate CC

UI --> S : Check-out complete\nDisplay itemised invoice\nOffer to print or email to guest
deactivate UI

@enduml
