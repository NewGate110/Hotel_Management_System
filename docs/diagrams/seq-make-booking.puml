@startuml HMS_Seq_MakeBooking
' Author: S2401265 Ahmed Aslan Ibrahim
' Sequence Diagram 1: Guest Makes a Booking

skinparam sequenceArrowThickness 2
skinparam roundcorner 8
skinparam sequenceParticipant underline
skinparam sequence {
  ParticipantBackgroundColor #EEF5FF
  ParticipantBorderColor #336699
  ActorBackgroundColor #FFF8E7
  ActorBorderColor #CC8800
  ArrowColor #336699
  LifeLineBorderColor #336699
}

title Guest Makes a Room Booking

actor Guest as G
participant "Angular\nFrontend" as UI
participant "RoomsController\n/api/rooms" as RC
participant "BookingsController\n/api/bookings" as BC
participant "RoomService" as RS
participant "BookingManagement\nService" as BS
database "PostgreSQL\nDatabase" as DB

== Search & Availability ==

G -> UI : Enter search criteria\n(hotel, dates, room type, guests, price)
activate UI

UI -> RC : GET /api/rooms/search\n?location&checkIn&checkOut&guests&roomType&minPrice&maxPrice
activate RC

RC -> RS : SearchRoomsAsync(criteria)
activate RS
RS -> DB : SELECT rooms with hotel JOIN\nWHERE not booked for date range\nAND capacity >= guests
activate DB
DB --> RS : List<Room>
deactivate DB
RS --> RC : RoomSearchResponse
deactivate RS

RC --> UI : 200 OK – RoomSearchResponse
deactivate RC

UI --> G : Display available rooms\nwith images, prices, and details

== Select Room & Optional Services ==

G -> UI : Click room → View Room Detail
UI --> G : Show room detail page with\nbooking wizard (dates pre-filled)

G -> UI : Select dates, guest count\nand optional ancillary services\n(e.g. Airport Transfer, Spa)
UI --> G : Show booking summary\nwith total cost breakdown

== Confirm Booking ==

G -> UI : Confirm booking
UI -> BC : POST /api/bookings/guest/{guestId}\n{roomIds, checkIn, checkOut, guestCount, serviceIds, notes}
activate BC

BC -> BS : CreateBookingAsync(guestId, dto)
activate BS

BS -> DB : BEGIN TRANSACTION
activate DB
BS -> DB : Validate room availability\n(check no overlapping confirmed bookings)
DB --> BS : rooms available

BS -> DB : INSERT Booking (status = Confirmed)
BS -> DB : INSERT BookingRooms (priceAtBooking snapshotted)
BS -> DB : INSERT BookingServices (if any selected)
BS -> DB : INSERT AuditLog (BookingCreated)
BS -> DB : COMMIT
DB --> BS : bookingId
deactivate DB

BS --> BC : BookingDto {id, reference, status, totalAmount}
deactivate BS

BC --> UI : 201 Created – BookingDto
deactivate BC

UI --> G : Booking confirmed\nShow booking reference + summary
deactivate UI

@enduml
