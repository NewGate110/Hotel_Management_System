@startuml HMS_UseCaseDiagram
' Author: S2401265 Ahmed Aslan Ibrahim

skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor #EEF5FF
  BorderColor #336699
}
skinparam actor {
  BackgroundColor #FFF8E7
  BorderColor #CC8800
}
skinparam ArrowColor #336699
skinparam linetype ortho

left to right direction

actor Guest          as G
actor "Front Desk\nStaff" as S
actor "Hotel\nManager"    as M
actor Admin          as A

rectangle "Hotel Management System" {

  ' ── Authentication (shared) ──
  usecase "Login"                         as UC_Login
  usecase "Logout"                        as UC_Logout
  usecase "Change Password"               as UC_ChangePw
  usecase "Forgot Password"               as UC_ForgotPw
  usecase "Reset Password"                as UC_ResetPw

  ' ── Guest use cases ──
  package "Guest Features" {
    usecase "Search Rooms\n(by hotel, type, price, dates)" as UC_Search
    usecase "View Room Details & Prices"  as UC_RoomDetail
    usecase "Make Booking"                as UC_Book
    usecase "View / Manage Bookings"      as UC_ViewBook
    usecase "Cancel Booking"              as UC_Cancel
    usecase "Add Ancillary Services"      as UC_Services
    usecase "View Booking History"        as UC_History
    usecase "View Invoice"                as UC_Invoice
    usecase "Manage Profile"              as UC_Profile
    usecase "Submit Contact Enquiry"      as UC_Contact
  }

  ' ── Front Desk Staff use cases ──
  package "Front Desk Features" {
    usecase "View Today's Arrivals"       as UC_Arrivals
    usecase "View Today's Departures"     as UC_Departures
    usecase "Create Walk-in Booking"      as UC_WalkIn
    usecase "Perform Guest Check-in"      as UC_Checkin
    usecase "Perform Guest Check-out"     as UC_Checkout
    usecase "Update Room Status"          as UC_RoomStatus
    usecase "Search Guests"               as UC_GuestSearch
    usecase "Edit Room Images\n(canManageMedia)" as UC_RoomImg
  }

  ' ── Hotel Manager use cases ──
  package "Manager Features" {
    usecase "View Occupancy Report"       as UC_OccRpt
    usecase "View Revenue Report"         as UC_RevRpt
    usecase "View Staff Performance"      as UC_StaffPerf
    usecase "Edit Room Images"            as UC_MgrRoomImg
  }

  ' ── Admin use cases ──
  package "Admin Features" {
    usecase "Manage All User Accounts\n(activate / deactivate / unlock)" as UC_UserAcc
    usecase "Manage Staff Accounts\n(create / update)" as UC_StaffAcc
    usecase "Toggle Staff Media Permission" as UC_MediaPerm
    usecase "Add / Edit Hotel"            as UC_Hotel
    usecase "Manage Room Pricing"         as UC_Pricing
    usecase "Edit Hotel Images"           as UC_HotelImg
    usecase "View Audit Logs"             as UC_Audit
  }

}

' ── Guest associations ──
G --> UC_Login
G --> UC_Logout
G --> UC_ChangePw
G --> UC_ForgotPw
G --> UC_Search
G --> UC_RoomDetail
G --> UC_Book
G --> UC_ViewBook
G --> UC_Cancel
G --> UC_Services
G --> UC_History
G --> UC_Invoice
G --> UC_Profile
G --> UC_Contact

' ── Forgot password includes reset ──
UC_ForgotPw ..> UC_ResetPw : <<include>>

' ── Booking includes services ──
UC_Book ..> UC_Services : <<extend>>
UC_ViewBook ..> UC_Cancel : <<extend>>

' ── Front Desk Staff associations ──
S --> UC_Login
S --> UC_Logout
S --> UC_ChangePw
S --> UC_Arrivals
S --> UC_Departures
S --> UC_WalkIn
S --> UC_Checkin
S --> UC_Checkout
S --> UC_RoomStatus
S --> UC_GuestSearch
S --> UC_RoomImg
S --> UC_Search

UC_Checkin  ..> UC_Arrivals   : <<include>>
UC_Checkout ..> UC_Departures : <<include>>

' ── Hotel Manager associations ──
M --> UC_Login
M --> UC_Logout
M --> UC_ChangePw
M --> UC_OccRpt
M --> UC_RevRpt
M --> UC_StaffPerf
M --> UC_MgrRoomImg

' ── Admin associations ──
A --> UC_Login
A --> UC_Logout
A --> UC_ChangePw
A --> UC_UserAcc
A --> UC_StaffAcc
A --> UC_MediaPerm
A --> UC_Hotel
A --> UC_Pricing
A --> UC_HotelImg
A --> UC_MgrRoomImg
A --> UC_Audit

' Admin can do everything a Manager can
A --|> M

@enduml
