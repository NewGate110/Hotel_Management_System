@startuml HMS_UseCaseDiagram
' Author: Aslan

skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor #EEF5FF
  BorderColor #336699
}
skinparam actor {
  BackgroundColor #FFF8E7
  BorderColor #CC8800
}
skinparam ArrowColor #336699
skinparam linetype ortho

left to right direction

actor Guest          as G
actor "Front Desk\nStaff" as S
actor "Hotel\nManager"    as M
actor Admin          as A

rectangle "Hotel Management System" {

  ' ── Authentication (shared) ──
  usecase "Login"                         as UC_Login
  usecase "Logout"                        as UC_Logout
  usecase "Reset Password"                as UC_ResetPw

  ' ── Guest use cases ──
  package "Guest Features" {
    usecase "Search Rooms"                as UC_Search
    usecase "View Room Details & Prices"  as UC_RoomDetail
    usecase "Check Availability"          as UC_Avail
    usecase "Make Booking"                as UC_Book
    usecase "View Booking"                as UC_ViewBook
    usecase "Cancel Booking"              as UC_Cancel
    usecase "Request Ancillary Services"  as UC_Services
    usecase "View Booking History"        as UC_History
    usecase "Download Invoice"            as UC_Invoice
    usecase "Manage Profile"              as UC_Profile
  }

  ' ── Front Desk Staff use cases ──
  package "Front Desk Features" {
    usecase "Manage Guest Booking\n(Create / Update / Cancel)" as UC_ManageBook
    usecase "Perform Guest Check-in"      as UC_Checkin
    usecase "Perform Guest Check-out"     as UC_Checkout
    usecase "Manage Room Status"          as UC_RoomStatus
    usecase "Process Payment"             as UC_Payment
    usecase "Generate Bill"               as UC_Bill
    usecase "Process Guest Service\nRequests" as UC_SvcReq
  }

  ' ── Hotel Manager use cases ──
  package "Manager Features" {
    usecase "View Occupancy Dashboard"    as UC_Dashboard
    usecase "Generate Occupancy Report"   as UC_OccRpt
    usecase "Generate Revenue Report"     as UC_RevRpt
    usecase "View Guest Demographics"     as UC_Demo
    usecase "Manage Room Rates"           as UC_Rates
    usecase "Manage Room Availability"    as UC_RoomAvail
    usecase "Manage Staff Accounts"       as UC_StaffAcc
  }

  ' ── Admin use cases ──
  package "Admin Features" {
    usecase "Manage All User Accounts"    as UC_UserAcc
    usecase "Add / Edit Hotel Location"   as UC_Hotel
    usecase "Configure System Settings"   as UC_Settings
  }

}

' ── Guest associations ──
G --> UC_Login
G --> UC_Logout
G --> UC_ResetPw
G --> UC_Search
G --> UC_RoomDetail
G --> UC_Avail
G --> UC_Book
G --> UC_ViewBook
G --> UC_Cancel
G --> UC_Services
G --> UC_History
G --> UC_Invoice
G --> UC_Profile

' ── Search includes availability check ──
UC_Search ..> UC_Avail  : <<include>>
UC_Book   ..> UC_Payment : <<include>>
UC_Book   ..> UC_Services : <<extend>>

' ── Front Desk Staff associations ──
S --> UC_Login
S --> UC_Logout
S --> UC_ManageBook
S --> UC_Checkin
S --> UC_Checkout
S --> UC_RoomStatus
S --> UC_Payment
S --> UC_Bill
S --> UC_SvcReq
S --> UC_Search

UC_Checkout ..> UC_Bill    : <<include>>
UC_Checkout ..> UC_Payment : <<include>>
UC_Checkin  ..> UC_ManageBook : <<include>>

' ── Hotel Manager associations ──
M --> UC_Login
M --> UC_Logout
M --> UC_Dashboard
M --> UC_OccRpt
M --> UC_RevRpt
M --> UC_Demo
M --> UC_Rates
M --> UC_RoomAvail
M --> UC_StaffAcc

' ── Admin associations ──
A --> UC_Login
A --> UC_Logout
A --> UC_UserAcc
A --> UC_Hotel
A --> UC_Settings
A --> UC_StaffAcc

' Admin extends Manager privileges
A --|> M

@enduml
