@startuml HMS_Seq_CheckIn
' Author: S2401265 Ahmed Aslan Ibrahim
' Sequence Diagram 2: Front Desk Staff Performs Guest Check-in

skinparam sequenceArrowThickness 2
skinparam roundcorner 8
skinparam sequenceParticipant underline
skinparam sequence {
  ParticipantBackgroundColor #EEF5FF
  ParticipantBorderColor #336699
  ActorBackgroundColor #FFF8E7
  ActorBorderColor #CC8800
  ArrowColor #336699
  LifeLineBorderColor #336699
}

title Front Desk Staff Performs Guest Check-in

actor "Front Desk\nStaff" as S
participant "Angular\nFrontend" as UI
participant "CheckInController\n/api/checkin" as CC
participant "BookingManagement\nService" as BS
database "PostgreSQL\nDatabase" as DB

== View Today's Arrivals ==

S -> UI : Open arrivals board
activate UI

UI -> CC : GET /api/checkin/arrivals
activate CC
CC -> BS : GetTodayArrivalsAsync()
activate BS
BS -> DB : SELECT Bookings WHERE status = Confirmed\nAND checkInDate = today
activate DB
DB --> BS : List<BookingDto>
deactivate DB
BS --> CC : List<BookingDto>
deactivate BS
CC --> UI : 200 OK – List<BookingDto>
deactivate CC

UI --> S : Display arrivals list\n(guest name, room, booking reference)

== Select Booking & Verify Guest ==

S -> UI : Select guest booking from list
UI --> S : Display booking details\n(guest, rooms, services, guest count)

S -> UI : Verify guest photo ID\nand confirm identity

== Perform Check-in ==

S -> UI : Click "Check In"
UI -> CC : POST /api/checkin/{bookingId}
activate CC

CC -> BS : CheckInAsync(bookingId, staffId)
activate BS

BS -> DB : SELECT Booking with rooms
activate DB
DB --> BS : BookingDetailDto
deactivate DB

alt Booking is Confirmed and today is check-in date
  BS -> DB : UPDATE Booking status = CheckedIn
  activate DB
  DB --> BS : OK
  deactivate DB

  BS -> DB : UPDATE Room status = Occupied\n(for each room in booking)
  activate DB
  DB --> BS : OK
  deactivate DB

  BS -> DB : INSERT AuditLog\n(CheckInPerformed, staffId, bookingId)
  activate DB
  DB --> BS : OK
  deactivate DB

  BS --> CC : BookingDto {status: CheckedIn}
  CC --> UI : 200 OK – BookingDto
  UI --> S : Check-in complete\nShow room number(s) to assign key

else Booking not in Confirmed status
  BS --> CC : 400 Bad Request
  CC --> UI : 400 – Cannot check in\n(wrong status or wrong date)
  UI --> S : Error message shown
end

deactivate BS
deactivate CC
deactivate UI

@enduml
